<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/theme_background">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/theme_background">
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="@string/player_profile"
            app:titleTextColor="@color/theme_primary"
            app:navigationIcon="@drawable/ic_back"
            app:navigationIconTint="@color/theme_primary" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Player Profile Header -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/TaskCard">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/productivity_score_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:textSize="48sp"
                        android:textStyle="bold"
                        android:textColor="@color/theme_tertiary"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="QUEST SUCCESS RATE"
                        android:textColor="@color/theme_text_primary"
                        android:textSize="14sp"
                        android:letterSpacing="0.1"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/player_stats"
                android:textColor="@color/theme_secondary"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginTop="16dp"
                android:layout_marginStart="8dp"/>

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:alignmentMode="alignMargins">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    style="@style/TaskCard">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <TextView
                            android:id="@+id/tasks_completed_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="@color/theme_success"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/stat_quests_done"
                            android:textColor="@color/theme_text_primary"
                            android:textSize="12sp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    style="@style/TaskCard">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <TextView
                            android:id="@+id/sessions_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="@color/theme_secondary"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="FOCUS SESSIONS"
                            android:textColor="@color/theme_text_primary"
                            android:textSize="12sp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    style="@style/TaskCard">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <TextView
                            android:id="@+id/streak_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 Days"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="@color/theme_tertiary"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/stat_streak"
                            android:textColor="@color/theme_text_primary"
                            android:textSize="12sp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    style="@style/TaskCard">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <TextView
                            android:id="@+id/total_focus_time_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0h"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="@color/theme_warning"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/stat_focus_power"
                            android:textColor="@color/theme_text_primary"
                            android:textSize="12sp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </GridLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/boss_goals"
                android:textColor="@color/theme_tertiary"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginTop="24dp"
                android:layout_marginStart="8dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/TaskCard">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DAILY FOCUS BOSS"
                        android:textColor="@color/theme_secondary"
                        android:textSize="12sp"
                        android:textStyle="bold"/>
                    <ProgressBar
                        android:id="@+id/daily_goal_progress"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="12dp"
                        android:layout_marginTop="8dp"
                        android:progress="0"
                        android:progressDrawable="@drawable/xp_bar_progress"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="WEEKLY QUEST CHALLENGE"
                        android:layout_marginTop="16dp"
                        android:textColor="@color/theme_tertiary"
                        android:textSize="12sp"
                        android:textStyle="bold"/>
                    <ProgressBar
                        android:id="@+id/weekly_goal_progress"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="12dp"
                        android:layout_marginTop="8dp"
                        android:progress="0"
                        android:progressDrawable="@drawable/xp_bar_progress"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/achievement_inventory"
                android:textColor="@color/theme_warning"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginTop="24dp"
                android:layout_marginStart="8dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/TaskCard">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:layout_marginHorizontal="8dp">
                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/badge_first_quest"
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:src="@drawable/add"
                            android:background="@drawable/badge_locked_bg"
                            android:padding="12dp"
                            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/badge_first_quest"
                            android:textSize="10sp"
                            android:layout_marginTop="4dp"
                            android:textColor="@color/theme_text_primary"
                            android:gravity="center"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:layout_marginHorizontal="8dp">
                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/badge_streak"
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:src="@drawable/ic_stats"
                            android:background="@drawable/badge_locked_bg"
                            android:padding="12dp"
                            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/badge_streak_starter"
                            android:textSize="10sp"
                            android:layout_marginTop="4dp"
                            android:textColor="@color/theme_text_primary"
                            android:gravity="center"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:layout_marginHorizontal="8dp">
                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/badge_focus_warrior"
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:src="@drawable/ic_timer"
                            android:background="@drawable/badge_locked_bg"
                            android:padding="12dp"
                            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/badge_focus_warrior"
                            android:textSize="10sp"
                            android:layout_marginTop="4dp"
                            android:textColor="@color/theme_text_primary"
                            android:gravity="center"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:layout_marginHorizontal="8dp">
                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/badge_boss_slayer"
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:src="@drawable/check"
                            android:background="@drawable/badge_locked_bg"
                            android:padding="12dp"
                            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/badge_boss_slayer"
                            android:textSize="10sp"
                            android:layout_marginTop="4dp"
                            android:textColor="@color/theme_text_primary"
                            android:gravity="center"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
